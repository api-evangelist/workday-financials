{
  "opencollection": "1.0.0",
  "info": {
    "name": "Workday Financials Workday Cash Management API",
    "version": "v38.2"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Bank Accounts",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Financials List bank accounts",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{tenant}.workday.com/api/cashManagement/v38.2/bankAccounts",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum number of results to return"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "Number of results to skip for pagination"
              },
              {
                "name": "active",
                "value": "",
                "type": "query",
                "description": "Filter by active status"
              }
            ]
          },
          "docs": "Retrieve a collection of bank accounts."
        },
        {
          "info": {
            "name": "Workday Financials Get a bank account",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{tenant}.workday.com/api/cashManagement/v38.2/bankAccounts/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "Unique identifier of the resource (WID)"
              }
            ]
          },
          "docs": "Retrieve details of a specific bank account."
        }
      ]
    },
    {
      "info": {
        "name": "Bank Transactions",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Financials List bank transactions for an account",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{tenant}.workday.com/api/cashManagement/v38.2/bankAccounts/:id/transactions",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "Unique identifier of the resource (WID)"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum number of results to return"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "Number of results to skip for pagination"
              },
              {
                "name": "fromDate",
                "value": "",
                "type": "query",
                "description": "Filter transactions from this date"
              },
              {
                "name": "toDate",
                "value": "",
                "type": "query",
                "description": "Filter transactions to this date"
              }
            ]
          },
          "docs": "Retrieve bank transactions associated with a specific bank account."
        }
      ]
    },
    {
      "info": {
        "name": "Cash Positions",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Financials List cash positions",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{tenant}.workday.com/api/cashManagement/v38.2/cashPositions",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum number of results to return"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "Number of results to skip for pagination"
              },
              {
                "name": "asOfDate",
                "value": "",
                "type": "query",
                "description": "Cash position as of this date"
              }
            ]
          },
          "docs": "Retrieve current cash positions across bank accounts."
        },
        {
          "info": {
            "name": "Workday Financials Get a cash position",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{tenant}.workday.com/api/cashManagement/v38.2/cashPositions/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "Unique identifier of the resource (WID)"
              }
            ]
          },
          "docs": "Retrieve details of a specific cash position."
        }
      ]
    },
    {
      "info": {
        "name": "Cash Forecasts",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Financials List cash forecasts",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{tenant}.workday.com/api/cashManagement/v38.2/cashForecasts",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum number of results to return"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "Number of results to skip for pagination"
              },
              {
                "name": "forecastDate",
                "value": "",
                "type": "query",
                "description": "Forecast for this date"
              }
            ]
          },
          "docs": "Retrieve cash forecast projections."
        }
      ]
    },
    {
      "info": {
        "name": "Payments",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Workday Financials List payments",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{tenant}.workday.com/api/cashManagement/v38.2/payments",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum number of results to return"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "Number of results to skip for pagination"
              },
              {
                "name": "status",
                "value": "",
                "type": "query",
                "description": "Filter by payment status"
              }
            ]
          },
          "docs": "Retrieve a collection of payments."
        },
        {
          "info": {
            "name": "Workday Financials Get a payment",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{tenant}.workday.com/api/cashManagement/v38.2/payments/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "Unique identifier of the resource (WID)"
              }
            ]
          },
          "docs": "Retrieve details of a specific payment."
        }
      ]
    }
  ],
  "bundled": true
}